{
    "name": "add-to-cart-backend",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "start:dev": "turbo start:dev --concurrency=11",
        "start:prod": "turbo start:prod",
        "lint": "turbo lint",
        "proto:gen": "turbo proto:gen",
        "db:generate": "turbo db:generate",
        "db:push": "turbo db:push",
        "db:migrate": "turbo db:migrate -- dev",
        "db:studio": "turbo db:studio",
        "db:all": "turbo db:generate && turbo db:migrate -- dev --name initial && turbo db:push",
        "db:seed": "turbo db:seed",
        "docker:dev:up": "docker compose -f docker-compose.dev.yml up --build -V",
        "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
        "docker:local:up": "docker compose -f docker-compose.local.yml up -d -V",
        "docker:local:down": "docker compose -f docker-compose.local.yml down",
        "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
        "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "lint:commit": "commitlint --edit",
        "lint:branch": "node ./scripts/check-branch.js",
        "setup:project": "turbo proto:gen && turbo db:generate && turbo build",
        "prepare": "husky",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:api-gateway": "jest --projects apps/api-gateway-service",
        "test:auth": "jest --projects apps/auth-management-service",
        "test:user": "jest --projects apps/user-management-service",
        "test:product": "jest --projects apps/product-management-service",
        "test:widget": "jest --projects apps/widget-management-service",
        "test:survey": "jest --projects apps/survey-management-service",
        "test:notification": "jest --projects apps/notification-management-service",
        "test:sample": "jest --projects apps/sample-management-service",
        "test:catalogue": "jest --projects apps/catalogue-management-service",
        "test:integration": "jest --testPathPattern=integration",
        "test:unit": "jest --testPathPattern=unit",
        "test:e2e": "jest --testPathPattern=e2e",
        "test:grpc": "jest --testPathPattern=grpc",
        "test:rest": "jest --testPathPattern=api",
        "test:ci": "jest --coverage --watchAll=false --passWithNoTests"
    },
    "devDependencies": {
        "@atc/typescript-config": "workspace:*",
        "@commitlint/cli": "^19.6.0",
        "@commitlint/config-conventional": "^19.6.0",
        "@types/express": "^5.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.10",
        "prettier": "^3.2.5",
        "turbo": "^2.4.4",
        "typescript": "5.5.4",
        "@types/jest": "^29.5.12",
        "@types/supertest": "^6.0.2",
        "@types/bcrypt": "^5.0.2",
        "@types/jsonwebtoken": "^9.0.7",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "supertest": "^7.0.0"
    },
    "packageManager": "pnpm@8.15.6",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "@atc/logger": "workspace:*",
        "@aws-sdk/client-s3": "^3.705.0",
        "@grpc/grpc-js": "^1.12.3",
        "@grpc/proto-loader": "^0.7.13",
        "@types/node": "^22.8.7",
        "dotenv": "^16.4.5",
        "dotenv-cli": "^7.4.2",
        "express": "^4.21.1",
        "winston": "^3.16.0",
        "zod": "^3.23.8",
        "zod-validation-error": "^3.4.0"
    }
}
